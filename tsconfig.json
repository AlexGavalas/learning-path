{
    "exclude": ["dist", "*.js"],
    "extends": "astro/tsconfigs/base",
    "compilerOptions": {
        "target": "ES2018",
        "strictNullChecks": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "composite": true,
        "paths": {
            "~api/*": ["./src/api/*"],
            "~components/*": ["./src/components/*"],
            "~config/*": ["./src/config/*"],
            "~content/*": ["./src/content/*"],
            "~layouts/*": ["./src/layouts/*"],
            "~lib/*": ["./src/lib/*"],
            "~pages/*": ["./src/pages/*"],
            "~styles/*": ["./src/styles/*"],
            "~test/*": ["./src/test/*"],
            "~types/*": ["./src/types/*"],
            "~constants": ["./src/constants.ts"]
        },
        "types": ["vitest/globals"]
    }
}
